{
  "name": "coherence-thesis",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "bootstrap": "node scripts/ensure-node-modules.mjs",
    "predev": "node scripts/ensure-node-modules.mjs",
    "dev": "next dev",
    "predev:e2e": "node scripts/ensure-node-modules.mjs",
    "dev:e2e": "NEXT_E2E_FAST=1 next dev --hostname 127.0.0.1 --port 3200",
    "prebuild": "node scripts/ensure-node-modules.mjs",
    "build": "npm run manuscripts:compile && next build",
    "prestart": "node scripts/ensure-node-modules.mjs",
    "start": "serve out -l 3100",
    "prepreview:static": "node scripts/ensure-node-modules.mjs",
    "preview:static": "serve out -l 3100",
    "prelint": "node scripts/ensure-node-modules.mjs",
    "lint": "eslint",
    "pretest": "node scripts/ensure-node-modules.mjs",
    "test": "vitest run",
    "pretest:e2e": "node scripts/ensure-node-modules.mjs",
    "test:e2e": "playwright test",
    "pretest:e2e:fast": "node scripts/ensure-node-modules.mjs",
    "test:e2e:fast": "PLAYWRIGHT_FAST=1 playwright test",
    "pretest:e2e:fast:desktop": "node scripts/ensure-node-modules.mjs",
    "test:e2e:fast:desktop": "PLAYWRIGHT_FAST=1 playwright test --project=desktop",
    "premanuscripts:import": "node scripts/ensure-node-modules.mjs",
    "manuscripts:import": "tsx scripts/manuscripts/import-markdown.ts",
    "premanuscripts:compile": "node scripts/ensure-node-modules.mjs",
    "manuscripts:compile": "tsx scripts/manuscripts/compile.ts",
    "premanuscripts:versions": "node scripts/ensure-node-modules.mjs",
    "manuscripts:versions": "tsx scripts/manuscripts/versions.ts",
    "premanuscripts:validate": "node scripts/ensure-node-modules.mjs",
    "manuscripts:validate": "tsx scripts/manuscripts/validate.ts",
    "prereadme:update": "node scripts/ensure-node-modules.mjs",
    "readme:update": "tsx scripts/update-readme-status.ts",
    "prevalidate": "node scripts/ensure-node-modules.mjs",
    "validate": "npm run manuscripts:compile && npm run manuscripts:validate && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pdfkit": "^0.19.1",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
